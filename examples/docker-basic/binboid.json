{
  "service": {
    "name": "binboid",
    "environment": "docker-local"
  },
  "control": {
    "listen_address": ":8080",
    "protocol_address": ":8081",
    "heartbeat_interval_seconds": 10,
    "flow_control": {
      "max_concurrent_streams": 100,
      "buffered_bytes_per_stream": 131072,
      "stream_timeout_seconds": 60,
      "stream_idle_timeout_seconds": 15
    }
  },
  "tunnel": {
    "public_host": "docker.binboi.local",
    "default_protocol": "http",
    "database_path": "./data/binboi-tunnels.json"
  },
  "proxy": {
    "forwarded_header": "X-Binboi-Session"
  },
  "auth": {
    "database_path": "./data/binboi-tokens.json",
    "cache_ttl_seconds": 30,
    "last_used_update_interval_seconds": 60
  },
  "observability": {
    "level": "info",
    "format": "text"
  }
}
